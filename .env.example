# Groq proxy (server-side only — never prefixed with VITE_, so it stays off the client)
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional. Defaults to llama-3.3-70b-versatile.
# GROQ_MODEL=llama-3.3-70b-versatile

# Early-access capture. If set, signups from the landing form are POSTed here as
# JSON ({ email, source, ts }). Works with Zapier, Make, Slack, Formspree, or any
# endpoint that accepts JSON. If left empty, signups are validated and accepted
# but only logged server-side (nothing is persisted).
# EARLY_ACCESS_WEBHOOK_URL=

# Optional durable rate limiting (recommended before a public deploy). When both
# are set, /api/chat and /api/subscribe throttle through Upstash Redis, which is
# correct across Vercel's many edge instances. If unset, an in-memory limiter is
# used (correct in dev and per-instance, best-effort across a fleet).
# Create a free database at https://console.upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
