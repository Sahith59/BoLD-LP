# Groq proxy (server-side only — never prefixed with VITE_, so it stays off the client)
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional. Defaults to llama-3.3-70b-versatile.
# GROQ_MODEL=llama-3.3-70b-versatile

# Early-access capture via Resend (the configured backend). On each signup we add
# the contact to a Resend Audience (the durable, exportable list), email you a
# notification, and email the user a confirmation. Get a key at
# https://resend.com/api-keys and create an Audience under Audiences.
# RESEND_API_KEY=
# RESEND_AUDIENCE_ID=
# EARLY_ACCESS_NOTIFY_EMAIL=you@yourdomain.com
# From address for both emails. Must be on a domain you have verified in Resend.
# Before verifying a domain you can use the Resend test sender below.
# EARLY_ACCESS_FROM_EMAIL=BoLD <onboarding@resend.dev>

# Fallback sink, used only when RESEND_API_KEY is not set. If set, signups are
# POSTed here as JSON ({ email, source, ts }). Works with Zapier, Make, Slack, or
# any endpoint that accepts JSON. If neither this nor Resend is set, signups are
# validated and accepted but only logged server-side (nothing is persisted).
# EARLY_ACCESS_WEBHOOK_URL=

# Optional durable rate limiting (recommended before a public deploy). When both
# are set, /api/chat and /api/subscribe throttle through Upstash Redis, which is
# correct across Vercel's many edge instances. If unset, an in-memory limiter is
# used (correct in dev and per-instance, best-effort across a fleet).
# Create a free database at https://console.upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# The live product entry (sign-in / sign-up page). The "Try the beta" buttons
# point here. Client-side, so it MUST be prefixed VITE_. Until set, the buttons
# fall back to a placeholder (https://app.yourdomain.com).
# VITE_APP_URL=https://app.yourdomain.com

# Cloudflare Web Analytics (privacy-first, cookieless, no banner needed). Get the
# token from your Cloudflare dashboard -> Web Analytics. Client-side, so VITE_.
# When unset, no analytics script loads.
# VITE_CF_ANALYTICS_TOKEN=

# Public contact email shown on the contact page (client-side, VITE_). Until set,
# the address is hidden and only the contact form is shown.
# VITE_CONTACT_EMAIL=hello@yourdomain.com

# Governing jurisdiction for the Terms (client-side, VITE_). When unset, the
# Terms use neutral phrasing. Example: "the State of Delaware, USA".
# VITE_LEGAL_JURISDICTION=

# Where contact-form messages are emailed (server-side). Falls back to
# EARLY_ACCESS_NOTIFY_EMAIL if unset. Requires RESEND_API_KEY to actually send.
# CONTACT_NOTIFY_EMAIL=you@yourdomain.com
